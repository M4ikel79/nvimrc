return {
  "nvzone/floaterm",
  dependencies = "nvzone/volt",
  keys = {
    { "<leader>tt", "<cmd>FloatermToggle<cr>", desc = "Toggle Floaterm" },
  },
  opts = {
    border = false,
    size = { h = 90, w = 90 }, -- Make it larger to feel more like a full screen
    mappings = {
      sidebar = function(buf)
        -- Toggle sidebar with <C-p> from within sidebar
        vim.keymap.set("n", "<C-p>", function()
          vim.api.nvim_win_close(0, false)
          vim.api.nvim_set_current_win(require("floaterm.state").win)
        end, { buffer = buf, desc = "Close sidebar" })
      end,
      term = function(buf)
        -- Toggle sidebar with <C-p> from terminal
        vim.keymap.set({ "n", "t" }, "<C-p>", function()
          require("floaterm.api").switch_wins()
        end, { buffer = buf, desc = "Toggle sidebar" })
      end,
    },
    terminals = {
      { name = "Terminal 1" },
      { name = "Terminal 2" },
    },
  },
}
